{
  // codeActionsOnSaveのexplicitはこれまでのtrueと同じ
  // 参考: https://code.visualstudio.com/updates/v1_83#_editor
  "editor.codeActionsOnSave": {
    // ESLintを含む全てのフォーマッターを実行
    // 参考: https://github.com/microsoft/vscode-eslint?tab=readme-ov-file#version-204
    "source.fixAll": "explicit"
  },
  // PrettierはcodeActionsOnSaveで実行されないので個別に設定
  // ignore設定は.prettierignoreファイルを作成する
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // 純粋なHTML（Vueディレクティブなどが含まれるhtmlなど）以外はPrettierで整形できないため
  // vscode.html-language-featuresを使う
  // 使わない時はコメントアウト
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  // GitHub Copilot設定
  // 全ての言語でCopilotを有効化
  "github.copilot.enable": {
    "*": true
  },
  // インライン候補の表示を有効化
  "editor.inlineSuggest.enabled": true,
  // 次の編集候補を自動表示（複数の変更を一度に提案）
  "github.copilot.nextEditSuggestions.enabled": true,
  // チャットでのコード自動修正を有効化
  "github.copilot.chat.agent.autoFix": true,
  // Copilot Chatの言語を日本語に設定
  "github.copilot.chat.localeOverride": "ja",
  // コミットメッセージは英語で生成
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Generate commit messages in English using conventional commits format. Keep the subject line as short as possible, ideally under 50 characters."
    }
  ],
  // プロジェクト固有のテンプレートを使用
  "github.copilot.chat.useProjectTemplates": true,
  // エディタ内でのクイックフィックス提案を有効化
  "github.copilot.editor.enableCodeActions": true,
  // 変数やメソッドのリネーム時に自動的に提案
  "github.copilot.renameSuggestions.triggerAutomatically": true,
  "chat.extensionUnification.enabled": false,
  "chat.tools.terminal.autoApprove": {
    "cd": true,
    "echo": true,
    "ls": true,
    "dir": true,
    "pwd": true,
    "cat": true,
    "head": true,
    "tail": true,
    "findstr": true,
    "wc": true,
    "tr": true,
    "cut": true,
    "cmp": true,
    "which": true,
    "basename": true,
    "dirname": true,
    "realpath": true,
    "readlink": true,
    "stat": true,
    "file": true,
    "od": true,
    "du": true,
    "df": true,
    "sleep": true,
    "nl": true,
    "grep": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+(status|log|show|diff|ls-files|grep|branch)\\b/": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+log\\b.*\\s--output(=|\\s|$)/": false,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+branch\\b.*\\s-(d|D|m|M|-delete|-force)\\b/": false,
    "/^docker\\s+(ps|images|info|version|inspect|logs|top|stats|port|diff|search|events)\\b/": true,
    "/^docker\\s+(container|image|network|volume|context|system)\\s+(ls|ps|inspect|history|show|df|info)\\b/": true,
    "/^docker\\s+compose\\s+(ps|ls|top|logs|images|config|version|port|events)\\b/": true,
    "/^Get-(ChildItem|Content|Date|Random|Location)\\b/": true,
    "/^(Set-Location|Write-Host|Write-Output|Out-String|Split-Path|Join-Path|Start-Sleep|Where-Object)\\b/": true,
    "/^Select-[a-z0-9]/i": true,
    "/^Measure-[a-z0-9]/i": true,
    "/^Compare-[a-z0-9]/i": true,
    "/^Format-[a-z0-9]/i": true,
    "/^Sort-[a-z0-9]/i": true,
    "/^npm\\s+(ls|list|outdated|view|info|show|explain|why|root|prefix|bin|search|doctor|fund|repo|bugs|docs|home|help(-search)?)\\b/": true,
    "/^npm\\s+config\\s+(list|get)\\b/": true,
    "/^npm\\s+pkg\\s+get\\b/": true,
    "/^npm\\s+audit$/": true,
    "/^npm\\s+cache\\s+verify\\b/": true,
    "/^yarn\\s+(list|outdated|info|why|bin|help|versions)\\b/": true,
    "/^yarn\\s+licenses\\b/": true,
    "/^yarn\\s+audit\\b(?!.*\\bfix\\b)/": true,
    "/^yarn\\s+config\\s+(list|get)\\b/": true,
    "/^yarn\\s+cache\\s+dir\\b/": true,
    "/^pnpm\\s+(ls|list|outdated|why|root|bin|doctor)\\b/": true,
    "/^pnpm\\s+licenses\\b/": true,
    "/^pnpm\\s+audit\\b(?!.*\\bfix\\b)/": true,
    "/^pnpm\\s+config\\s+(list|get)\\b/": true,
    "column": true,
    "/^column\\b.*\\s-c\\s+[0-9]{4,}/": false,
    "date": true,
    "/^date\\b.*\\s(-s|--set)\\b/": false,
    "find": true,
    "/^find\\b.*\\s-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
    "rg": true,
    "/^rg\\b.*\\s(--pre|--hostname-bin)\\b/": false,
    "sed": true,
    "/^sed\\b.*\\s(-[a-zA-Z]*(e|f)[a-zA-Z]*|--expression|--file)\\b/": false,
    "/^sed\\b.*s\\/.*\\/.*\\/[ew]/": false,
    "/^sed\\b.*;W/": false,
    "sort": true,
    "/^sort\\b.*\\s-(o|S)\\b/": false,
    "tree": true,
    "/^tree\\b.*\\s-o\\b/": false,
    "/^xxd\\b(\\s+-\\S+)*\\s+[^-\\s]\\S*$/": true
  }
}
